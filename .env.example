# ════════════════════════════════════════════════════════════════
#  EmbeddedCamps — Environment Variables
#  Copy this file to .env and fill in ALL values before deploying.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL plugin.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:STRONG_PASSWORD@localhost:5432/embeddedcamp

# ── JWT Secrets ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ACCESS token is short-lived (15m). REFRESH token is long-lived (30d).
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
ALLOWED_ORIGINS=https://aospcamp.com,https://www.aospcamp.com,https://embeddedcamps.com

# ── App URLs ──────────────────────────────────────────────────────
# Used in email links. Must match your actual domain.
APP_URL=https://aospcamp.com
API_URL=https://api.aospcamp.com

# ── Bunny.net Storage + CDN ───────────────────────────────────────
# 1. Create a Storage Zone in Bunny.net dashboard
# 2. Create a Pull Zone linked to the Storage Zone
# 3. Enable "Token Authentication" on the Pull Zone for signed URLs
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_API_KEY=your-storage-zone-password-from-bunny-dashboard
BUNNY_CDN_URL=https://your-pull-zone.b-cdn.net
BUNNY_TOKEN_SECRET=your-pull-zone-token-auth-secret

# ── Email (SMTP) ──────────────────────────────────────────────────
# Option A: Gmail App Password
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate a password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@embeddedcamps.com
SMTP_PASS=your-gmail-app-password-16-chars
EMAIL_FROM=EmbeddedCamps <support@embeddedcamps.com>

# Option B: Brevo (300 free emails/day)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email
# SMTP_PASS=your-brevo-smtp-key

# Option C: Resend (3,000 free emails/month — recommended)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=your-resend-api-key
