generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum CampStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum MaterialType {
  VIDEO
  PDF
  LINK
  RESOURCE
  ARTICLE
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CampLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BrandStatus {
  LIVE
  COMING_SOON
  ARCHIVED
}

enum OrderStatus {
  PENDING
  VERIFIED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  INSTAPAY
  IBAN
  WALLET
  OTHER
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String?
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments       Enrollment[]
  quizAttempts      QuizAttempt[]
  labSubmissions    LabSubmission[]
  materialProgress  MaterialProgress[]
  certificates      Certificate[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  feedbackGiven     Feedback[]
  announcements     Announcement[]
  notes             Note[]
  bookmarks         Bookmark[]
  orders            Order[]        @relation("OrderUser")
  ordersVerified    Order[]        @relation("OrderVerifiedBy")
}

// ─── Auth Tokens ──────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Brand ───────────────────────────────────────────────────────────────────

model Brand {
  id          String      @id @default(uuid())
  name        String      @unique  // e.g. "AOSPCamp"
  slug        String      @unique  // e.g. "aosp"
  tagline     String?               // short pitch line
  description String?
  icon        String?               // emoji or icon name
  color       String?               // hex or Tailwind class hint
  status      BrandStatus @default(COMING_SOON)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  camps Camp[]

  @@index([status])
}

// ─── Camp ────────────────────────────────────────────────────────────────────

model Camp {
  id             String     @id @default(uuid())
  title          String
  slug           String?    @unique  // SEO-friendly URL segment
  description    String?
  thumbnail      String?
  price          Decimal    @default(0)
  startDate      DateTime?
  endDate        DateTime?
  status         CampStatus @default(UPCOMING)
  level          CampLevel  @default(BEGINNER)
  language       String     @default("English")
  whatYouLearn   Json?      // String[]
  prerequisites  Json?      // String[]
  brandId        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  brand         Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  campSessions  CampSession[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  announcements Announcement[]
  orders        Order[]

  @@index([status])
  @@index([brandId])
  @@index([slug])
}

// ─── MasterSession (reusable across camps) ───────────────────────────────────

model MasterSession {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   @default("General")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campSessions CampSession[]
  materials    Material[]
  quizzes      Quiz[]
  labs         Lab[]

  @@index([category])
}

model CampSession {
  id              String  @id @default(uuid())
  campId          String
  masterSessionId String
  isVisible       Boolean @default(false)
  order           Int     @default(0)

  camp          Camp          @relation(fields: [campId], references: [id], onDelete: Cascade)
  masterSession MasterSession @relation(fields: [masterSessionId], references: [id], onDelete: Cascade)

  @@unique([campId, masterSessionId])
}

// ─── Material ────────────────────────────────────────────────────────────────

model Material {
  id              String       @id @default(uuid())
  title           String
  type            MaterialType @default(VIDEO)
  url             String?
  masterSessionId String
  order           Int          @default(0)
  duration        Int?
  content         String?      // Markdown/HTML content for ARTICLE type
  createdAt       DateTime     @default(now())

  masterSession MasterSession      @relation(fields: [masterSessionId], references: [id], onDelete: Cascade)
  progress      MaterialProgress[]
  notes         Note[]
  bookmarks     Bookmark[]
}

// ─── Bookmark ────────────────────────────────────────────────────────────────

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  materialId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([userId])
  @@index([materialId])
}

// ─── Lab ─────────────────────────────────────────────────────────────────────

model Lab {
  id              String    @id @default(uuid())
  title           String
  description     String?   // Brief overview shown to students
  instructionsUrl String?   // Link to full instructions PDF/document
  solutionContent String?   // Full solution text (admin/instructor only)
  solutionUrl     String?   // Link to solution PDF (admin/instructor only)
  masterSessionId String
  dueDate         DateTime?
  createdAt       DateTime  @default(now())

  masterSession MasterSession   @relation(fields: [masterSessionId], references: [id], onDelete: Cascade)
  submissions   LabSubmission[]

  @@index([masterSessionId])
}

model LabSubmission {
  id          String   @id @default(uuid())
  labId       String
  userId      String
  content     String?
  fileUrl     String?
  submittedAt DateTime @default(now())

  lab      Lab        @relation(fields: [labId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback Feedback?

  @@index([labId])
  @@index([userId])
}

model Feedback {
  id           String   @id @default(uuid())
  submissionId String   @unique
  instructorId String
  content      String
  grade        Int?
  createdAt    DateTime @default(now())

  submission LabSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  instructor User          @relation(fields: [instructorId], references: [id])

  @@index([instructorId])
}


// ─── Quiz ──────────────────────────────────────────────────────────────────────

model Quiz {
  id              String   @id @default(uuid())
  title           String
  passMark        Int      @default(70)
  masterSessionId String
  createdAt       DateTime @default(now())

  masterSession MasterSession @relation(fields: [masterSessionId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      QuizAttempt[]

  @@index([masterSessionId])
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  text          String
  options       Json
  correctOption Int      @default(0)
  order         Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  answers   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

// ─── Progress ────────────────────────────────────────────────────────────────

model MaterialProgress {
  id         String   @id @default(uuid())
  userId     String
  materialId String
  completed  Boolean  @default(false)
  watchTime  Int      @default(0)
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([userId])
  @@index([materialId])
}

// ─── Enrollment ─────────────────────────────────────────────────────────────

model Enrollment {
  id         String           @id @default(uuid())
  userId     String
  campId     String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@unique([userId, campId])
  @@index([userId])
  @@index([campId])
  @@index([enrolledAt])
  @@index([status])
}

// ─── Certificate ────────────────────────────────────────────────────────────

model Certificate {
  id                     String    @id @default(uuid())
  certificateId          String?   @unique
  userId                 String
  campId                 String
  studentName            String?
  courseName             String?
  completionDate         DateTime  @default(now())
  issueDate              DateTime  @default(now())
  expirationDate         DateTime?
  verificationUrl        String?
  pdfUrl                 String?
  status                 String    @default("ACTIVE") // ACTIVE, REVOKED
  downloadsCount         Int       @default(0)
  verificationScansCount Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@unique([userId, campId])
  @@index([userId])
  @@index([campId])
  @@index([certificateId])
}

// ─── Announcement ─────────────────────────────────────────────────────────────

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  campId      String?
  createdById String
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  camp      Camp? @relation(fields: [campId], references: [id], onDelete: SetNull)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([campId])
  @@index([publishedAt])
}

// ─── Note ───────────────────────────────────────────────────────────────────────

model Note {
  id         String   @id @default(uuid())
  userId     String
  materialId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([userId])
  @@index([materialId])
}

// ─── Order ───────────────────────────────────────────────────────────────────────

model Order {
  id            String        @id @default(uuid())
  userId        String?
  campId        String
  studentName   String
  studentEmail  String
  amount        Decimal
  currency      String        @default("EGP")
  paymentMethod PaymentMethod @default(INSTAPAY)
  status        OrderStatus   @default(PENDING)
  receiptUrl    String?
  paymentRef    String?
  notes         String?
  verifiedById  String?
  verifiedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  camp       Camp  @relation(fields: [campId], references: [id], onDelete: Cascade)
  user       User? @relation("OrderUser", fields: [userId], references: [id], onDelete: SetNull)
  verifiedBy User? @relation("OrderVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campId])
  @@index([status])
  @@index([createdAt])
}